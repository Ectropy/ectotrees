{
  "name": "ectotrees-alt1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && node scripts/copy-appconfig.mjs",
    "dev": "vite build --mode development && node scripts/copy-appconfig.mjs",
    "watch": "node scripts/copy-appconfig.mjs && vite build --mode development --watch",
    "serve": "vite --host --port 5173",
    "preview": "vite preview --host",
    "serve:dist": "npm run build && npm run preview"
  },
  "dependencies": {
    "alt1": "^0.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0",
    "vite": "^7.1.0"
  }
}
