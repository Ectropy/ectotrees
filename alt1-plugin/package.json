{
  "name": "ectotrees-alt1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "vite build && node scripts/copy-appconfig.mjs",
    "dev": "vite build --mode development && node scripts/copy-appconfig.mjs",
    "watch": "node scripts/copy-appconfig.mjs && vite build --mode development --watch",
    "serve": "vite --host --port 5173",
    "preview": "vite preview --host",
    "serve:dist": "npm run build && npm run preview"
  },
  "dependencies": {
    "alt1": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.0"
  }
}
