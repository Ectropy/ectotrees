{
  "permissions": {
    "allow": [
      // Let Claude read any file without prompting
      "Read",
      // Let Claude search files freely
      "Glob",
      "Grep",
      // Allow running build, server check, and e2e test scripts
      "Bash(npm run build:*)",
      "Bash(npm run server:check:*)",
      "Bash(npm run test:e2e:*)",
      // Allow git status and diff (read-only git)
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ]
  }
}
